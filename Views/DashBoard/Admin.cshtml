@{
    ViewData["Title"] = "Admin Paneli";
    Layout = null;

    // Şimdilik tasarımı görebilmek için örnek veriler kullanılıyor.
    // Controller ve ViewModel hazırlandığında bu değerler veritabanından gelecek.
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MusicProject</title>

    <style>
        :root {
            --background: #080b09;
            --sidebar: #0d110f;
            --card: #121713;
            --card-hover: #171e19;
            --border: rgba(255, 255, 255, 0.08);
            --primary: #1ed760;
            --primary-dark: #18b950;
            --text: #ffffff;
            --text-secondary: #9da6a0;
            --danger: #ff5c5c;
            --warning: #ffbd3d;
            --info: #55aaff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            min-height: 100vh;
            overflow-x: hidden;
            color: var(--text);
            background:
                radial-gradient(
                    circle at 75% 5%,
                    rgba(30, 215, 96, 0.10),
                    transparent 24%
                ),
                var(--background);
            font-family:
                Inter,
                Arial,
                Helvetica,
                sans-serif;
        }

        button,
        input,
        select {
            font-family: inherit;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .admin-layout {
            min-height: 100vh;
            display: flex;
        }

        /* ==============================
           SOL MENÜ
        ============================== */

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            width: 265px;
            height: 100vh;
            padding: 24px 17px;
            display: flex;
            flex-direction: column;
            background-color: rgba(13, 17, 15, 0.97);
            border-right: 1px solid var(--border);
            backdrop-filter: blur(15px);
            transition: transform 0.25s ease;
        }

        .brand {
            padding: 0 12px 26px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border);
        }

        .brand-icon {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #071009;
            background-color: var(--primary);
            border-radius: 14px;
            font-size: 24px;
            font-weight: 900;
            box-shadow: 0 8px 25px rgba(30, 215, 96, 0.22);
        }

        .brand-name {
            display: block;
            font-size: 19px;
            font-weight: 800;
            letter-spacing: 0.2px;
        }

        .brand-panel {
            display: block;
            margin-top: 3px;
            color: var(--text-secondary);
            font-size: 12px;
        }

        .navigation {
            margin-top: 26px;
            flex: 1;
        }

        .navigation-title {
            margin: 0 13px 10px;
            color: #687169;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 1.4px;
            text-transform: uppercase;
        }

        .navigation-list {
            list-style: none;
        }

        .navigation-item {
            margin-bottom: 6px;
        }

        .navigation-link {
            width: 100%;
            min-height: 48px;
            padding: 0 14px;
            display: flex;
            align-items: center;
            gap: 13px;
            color: var(--text-secondary);
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            transition: 0.2s ease;
        }

        .navigation-link:hover {
            color: var(--text);
            background-color: rgba(255, 255, 255, 0.05);
        }

        .navigation-link.active {
            color: #061108;
            background-color: var(--primary);
            box-shadow: 0 9px 28px rgba(30, 215, 96, 0.16);
        }

        .navigation-icon {
            width: 23px;
            text-align: center;
            font-size: 18px;
        }

        .navigation-badge {
            min-width: 24px;
            margin-left: auto;
            padding: 4px 7px;
            color: white;
            background-color: rgba(255, 255, 255, 0.12);
            border-radius: 20px;
            text-align: center;
            font-size: 11px;
        }

        .navigation-link.active .navigation-badge {
            color: white;
            background-color: rgba(0, 0, 0, 0.25);
        }

        .sidebar-footer {
            padding-top: 17px;
            border-top: 1px solid var(--border);
        }

        .admin-profile {
            padding: 11px;
            display: flex;
            align-items: center;
            gap: 11px;
            border-radius: 13px;
            background-color: rgba(255, 255, 255, 0.035);
        }

        .admin-avatar {
            width: 39px;
            height: 39px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #08110a;
            background-color: var(--primary);
            border-radius: 50%;
            font-weight: 900;
        }

        .admin-profile-info {
            min-width: 0;
            flex: 1;
        }

        .admin-name {
            overflow: hidden;
            font-size: 13px;
            font-weight: 800;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .admin-role {
            margin-top: 3px;
            color: var(--text-secondary);
            font-size: 11px;
        }

        .logout-button {
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            background: transparent;
            border: none;
            border-radius: 9px;
            cursor: pointer;
            transition: 0.2s;
        }

        .logout-button:hover {
            color: var(--danger);
            background-color: rgba(255, 92, 92, 0.1);
        }

        /* ==============================
           ANA İÇERİK
        ============================== */

        .main-content {
            width: calc(100% - 265px);
            min-height: 100vh;
            margin-left: 265px;
        }

        .topbar {
            position: sticky;
            top: 0;
            z-index: 900;
            min-height: 78px;
            padding: 16px 34px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: rgba(8, 11, 9, 0.83);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(18px);
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .menu-button {
            width: 42px;
            height: 42px;
            display: none;
            align-items: center;
            justify-content: center;
            color: white;
            background-color: var(--card);
            border: 1px solid var(--border);
            border-radius: 11px;
            font-size: 20px;
            cursor: pointer;
        }

        .page-heading h1 {
            font-size: 22px;
            font-weight: 850;
        }

        .page-heading p {
            margin-top: 5px;
            color: var(--text-secondary);
            font-size: 13px;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 11px;
        }

        .search-box {
            width: 270px;
            height: 43px;
            padding: 0 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            background-color: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
        }

        .search-box span {
            color: var(--text-secondary);
        }

        .search-box input {
            width: 100%;
            color: white;
            background: transparent;
            border: none;
            outline: none;
            font-size: 13px;
        }

        .search-box input::placeholder {
            color: #69716c;
        }

        .notification-button {
            position: relative;
            width: 43px;
            height: 43px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            background-color: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            cursor: pointer;
        }

        .notification-dot {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 7px;
            height: 7px;
            background-color: var(--primary);
            border: 2px solid var(--card);
            border-radius: 50%;
        }

        .dashboard-content {
            padding: 32px 34px 50px;
        }

        .welcome-banner {
            position: relative;
            overflow: hidden;
            min-height: 180px;
            padding: 34px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background:
                linear-gradient(
                    125deg,
                    rgba(30, 215, 96, 0.20),
                    rgba(18, 23, 19, 0.95) 55%
                );
            border: 1px solid rgba(30, 215, 96, 0.20);
            border-radius: 22px;
        }

        .welcome-banner::after {
            content: "♪";
            position: absolute;
            right: 50px;
            color: rgba(30, 215, 96, 0.13);
            font-size: 155px;
            font-weight: bold;
            transform: rotate(-12deg);
        }

        .welcome-content {
            position: relative;
            z-index: 1;
        }

        .welcome-label {
            margin-bottom: 10px;
            color: var(--primary);
            font-size: 12px;
            font-weight: 850;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }

        .welcome-title {
            margin-bottom: 10px;
            font-size: clamp(25px, 3vw, 38px);
            line-height: 1.15;
        }

        .welcome-description {
            max-width: 620px;
            color: var(--text-secondary);
            font-size: 14px;
            line-height: 1.7;
        }

        .welcome-date {
            position: relative;
            z-index: 1;
            min-width: 150px;
            padding: 14px 18px;
            color: #d9e1dc;
            background-color: rgba(0, 0, 0, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 13px;
            text-align: center;
            font-size: 13px;
        }

        /* ==============================
           İSTATİSTİK KARTLARI
        ============================== */

        .stat-grid {
            margin-top: 25px;
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 18px;
        }

        .stat-card {
            min-height: 145px;
            padding: 21px;
            background-color: var(--card);
            border: 1px solid var(--border);
            border-radius: 18px;
            transition: 0.22s ease;
        }

        .stat-card:hover {
            background-color: var(--card-hover);
            border-color: rgba(30, 215, 96, 0.22);
            transform: translateY(-3px);
        }

        .stat-card-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .stat-icon {
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 13px;
            font-size: 20px;
        }

        .green-icon {
            color: var(--primary);
            background-color: rgba(30, 215, 96, 0.11);
        }

        .blue-icon {
            color: var(--info);
            background-color: rgba(85, 170, 255, 0.11);
        }

        .orange-icon {
            color: var(--warning);
            background-color: rgba(255, 189, 61, 0.11);
        }

        .red-icon {
            color: var(--danger);
            background-color: rgba(255, 92, 92, 0.11);
        }

        .stat-change {
            padding: 5px 8px;
            color: var(--primary);
            background-color: rgba(30, 215, 96, 0.09);
            border-radius: 8px;
            font-size: 11px;
            font-weight: 800;
        }

        .stat-number {
            margin-top: 20px;
            font-size: 28px;
            font-weight: 900;
        }

        .stat-label {
            margin-top: 6px;
            color: var(--text-secondary);
            font-size: 13px;
        }

        /* ==============================
           ORTA BÖLÜM
        ============================== */

        .dashboard-grid {
            margin-top: 25px;
            display: grid;
            grid-template-columns: minmax(0, 1.55fr) minmax(300px, 0.75fr);
            gap: 20px;
        }

        .panel {
            background-color: var(--card);
            border: 1px solid var(--border);
            border-radius: 19px;
        }

        .panel-header {
            min-height: 69px;
            padding: 18px 21px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--border);
        }

        .panel-title {
            font-size: 16px;
            font-weight: 850;
        }

        .panel-subtitle {
            margin-top: 4px;
            color: var(--text-secondary);
            font-size: 12px;
        }

        .panel-link {
            color: var(--primary);
            font-size: 12px;
            font-weight: 750;
        }

        .chart-area {
            height: 285px;
            padding: 27px 22px 18px;
            display: flex;
            align-items: flex-end;
            gap: 13px;
        }

        .chart-column {
            height: 100%;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            gap: 10px;
        }

        .chart-bar-wrapper {
            height: 220px;
            display: flex;
            align-items: flex-end;
        }

        .chart-bar {
            width: 100%;
            min-height: 12px;
            background:
                linear-gradient(
                    180deg,
                    var(--primary),
                    rgba(30, 215, 96, 0.22)
                );
            border-radius: 8px 8px 3px 3px;
            transition: 0.2s;
        }

        .chart-bar:hover {
            filter: brightness(1.16);
            transform: scaleX(1.04);
        }

        .chart-label {
            color: var(--text-secondary);
            text-align: center;
            font-size: 11px;
        }

        .quick-actions {
            padding: 17px;
            display: grid;
            gap: 11px;
        }

        .quick-action {
            min-height: 64px;
            padding: 13px;
            display: flex;
            align-items: center;
            gap: 13px;
            background-color: rgba(255, 255, 255, 0.025);
            border: 1px solid transparent;
            border-radius: 13px;
            transition: 0.2s;
        }

        .quick-action:hover {
            background-color: rgba(255, 255, 255, 0.055);
            border-color: var(--border);
            transform: translateX(3px);
        }

        .quick-action-icon {
            width: 39px;
            height: 39px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            background-color: rgba(30, 215, 96, 0.09);
            border-radius: 11px;
        }

        .quick-action-content {
            min-width: 0;
            flex: 1;
        }

        .quick-action-title {
            font-size: 13px;
            font-weight: 800;
        }

        .quick-action-description {
            margin-top: 4px;
            overflow: hidden;
            color: var(--text-secondary);
            font-size: 11px;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .quick-action-arrow {
            color: #5c655f;
        }

        /* ==============================
           TABLOLAR
        ============================== */

        .tables-grid {
            margin-top: 25px;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 20px;
        }

        .table-wrapper {
            overflow-x: auto;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th,
        .data-table td {
            padding: 15px 18px;
            border-bottom: 1px solid var(--border);
            text-align: left;
            white-space: nowrap;
        }

        .data-table th {
            color: #687169;
            font-size: 10px;
            font-weight: 850;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        .data-table td {
            color: #d8ded9;
            font-size: 12px;
        }

        .data-table tbody tr {
            transition: 0.2s;
        }

        .data-table tbody tr:hover {
            background-color: rgba(255, 255, 255, 0.025);
        }

        .data-table tbody tr:last-child td {
            border-bottom: none;
        }

        .user-cell,
        .song-cell {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .table-avatar,
        .song-cover {
            width: 37px;
            height: 37px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: #071008;
            background-color: var(--primary);
            border-radius: 10px;
            font-size: 13px;
            font-weight: 900;
        }

        .song-cover {
            color: var(--primary);
            background:
                linear-gradient(
                    135deg,
                    #1d3324,
                    #0c110e
                );
        }

        .cell-title {
            color: white;
            font-size: 12px;
            font-weight: 750;
        }

        .cell-subtitle {
            margin-top: 3px;
            color: var(--text-secondary);
            font-size: 10px;
        }

        .role-badge,
        .status-badge {
            display: inline-flex;
            padding: 5px 9px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 800;
        }

        .role-user {
            color: var(--info);
            background-color: rgba(85, 170, 255, 0.10);
        }

        .role-artist {
            color: var(--primary);
            background-color: rgba(30, 215, 96, 0.10);
        }

        .role-admin {
            color: var(--warning);
            background-color: rgba(255, 189, 61, 0.10);
        }

        .status-active {
            color: var(--primary);
            background-color: rgba(30, 215, 96, 0.10);
        }

        .table-action {
            padding: 7px 10px;
            color: #dce1dd;
            background-color: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 10px;
            cursor: pointer;
            transition: 0.2s;
        }

        .table-action:hover {
            color: #071008;
            background-color: var(--primary);
        }

        /* ==============================
           MOBİL UYUMLULUK
        ============================== */

        .sidebar-overlay {
            position: fixed;
            inset: 0;
            z-index: 950;
            display: none;
            background-color: rgba(0, 0, 0, 0.65);
        }

        @@media (max-width: 1200px) {
            .stat-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .dashboard-grid,
            .tables-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 900px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .sidebar-overlay.open {
                display: block;
            }

            .main-content {
                width: 100%;
                margin-left: 0;
            }

            .menu-button {
                display: flex;
            }

            .search-box {
                width: 210px;
            }
        }

        @@media (max-width: 650px) {
            .topbar {
                padding: 14px 17px;
            }

            .page-heading p {
                display: none;
            }

            .search-box {
                display: none;
            }

            .dashboard-content {
                padding: 20px 16px 35px;
            }

            .welcome-banner {
                min-height: 205px;
                padding: 25px;
                align-items: flex-start;
                flex-direction: column;
                gap: 20px;
            }

            .welcome-banner::after {
                right: 15px;
                bottom: -30px;
                font-size: 120px;
            }

            .welcome-date {
                min-width: 0;
                padding: 9px 13px;
            }

            .stat-grid {
                grid-template-columns: 1fr;
            }

            .chart-area {
                gap: 7px;
            }

            .data-table th,
            .data-table td {
                padding: 13px 14px;
            }
        }
    </style>
</head>

<body>

    <div class="admin-layout">

        <!-- SOL MENÜ -->
        <aside class="sidebar" id="sidebar">

            <a href="/" class="brand">

                <div class="brand-icon">
                    ♪
                </div>

                <div>
                    <span class="brand-name">
                        MusicProject
                    </span>

                    <span class="brand-panel">
                        Yönetim paneli
                    </span>
                </div>

            </a>

            <nav class="navigation">

                <p class="navigation-title">
                    Yönetim
                </p>

                <ul class="navigation-list">

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link active">

                            <span class="navigation-icon">
                                ▦
                            </span>

                            Genel Bakış
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                👥
                            </span>

                            Kullanıcılar

                            <span class="navigation-badge">
                                248
                            </span>
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ★
                            </span>

                            Sanatçılar

                            <span class="navigation-badge">
                                36
                            </span>
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ♫
                            </span>

                            Şarkılar

                            <span class="navigation-badge">
                                514
                            </span>
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ▤
                            </span>

                            İstatistikler
                        </a>
                    </li>

                </ul>

                <p class="navigation-title"
                   style="margin-top: 27px;">
                    Sistem
                </p>

                <ul class="navigation-list">

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ⚙
                            </span>

                            Ayarlar
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="/"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ↗
                            </span>

                            Siteyi Görüntüle
                        </a>
                    </li>

                </ul>

            </nav>

            <div class="sidebar-footer">

                <div class="admin-profile">

                    <div class="admin-avatar">
                        A
                    </div>

                    <div class="admin-profile-info">

                        <div class="admin-name">
                            Sistem Yöneticisi
                        </div>

                        <div class="admin-role">
                            Admin
                        </div>

                    </div>

                    <a href="/Auth/Logout"
                       class="logout-button"
                       title="Çıkış Yap">
                        ↪
                    </a>

                </div>

            </div>

        </aside>

        <div class="sidebar-overlay"
             id="sidebarOverlay">
        </div>

        <!-- ANA İÇERİK -->
        <main class="main-content">

            <header class="topbar">

                <div class="topbar-left">

                    <button type="button"
                            class="menu-button"
                            id="menuButton">
                        ☰
                    </button>

                    <div class="page-heading">
