@model MusicProject.Models.ViewModels.UserDashboardViewModel

@{
    ViewData["Title"] = "Kullanıcı Paneli";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MusicProject</title>

    <style>
            :root {
                --background: #080b09;
                --sidebar: #0d110f;
                --card: #121713;
                --card-hover: #181e1a;
                --border: rgba(255, 255, 255, 0.08);
                --primary: #1ed760;
                --primary-hover: #28e96d;
                --text: #ffffff;
                --text-secondary: #9da6a0;
                --danger: #ff5c5c;
                --warning: #ffbd3d;
                --info: #55aaff;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                min-height: 100vh;
                overflow-x: hidden;
                color: var(--text);
                background: radial-gradient( circle at 82% 3%, rgba(30, 215, 96, 0.12), transparent 27% ), var(--background);
                font-family: Arial, Helvetica, sans-serif;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            button,
            input {
                font-family: inherit;
            }

            button {
                cursor: pointer;
            }

            .user-layout {
                min-height: 100vh;
                display: flex;
            }

            /* =========================================
                       SOL MENÜ
                    ========================================= */

            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                z-index: 1000;
                width: 265px;
                height: 100vh;
                padding: 24px 17px;
                display: flex;
                flex-direction: column;
                background-color: rgba(13, 17, 15, 0.97);
                border-right: 1px solid var(--border);
                backdrop-filter: blur(16px);
                transition: transform 0.25s ease;
            }

            .brand {
                padding: 0 12px 26px;
                display: flex;
                align-items: center;
                gap: 12px;
                border-bottom: 1px solid var(--border);
            }

            .brand-icon {
                width: 44px;
                height: 44px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #071009;
                background-color: var(--primary);
                border-radius: 14px;
                font-size: 24px;
                font-weight: 900;
                box-shadow: 0 8px 25px rgba(30, 215, 96, 0.22);
            }

            .brand-name {
                display: block;
                font-size: 19px;
                font-weight: 800;
            }

            .brand-panel {
                display: block;
                margin-top: 3px;
                color: var(--text-secondary);
                font-size: 12px;
            }

            .navigation {
                margin-top: 26px;
                flex: 1;
            }

            .navigation-title {
                margin: 0 13px 10px;
                color: #687169;
                font-size: 11px;
                font-weight: 800;
                letter-spacing: 1.4px;
                text-transform: uppercase;
            }

            .navigation-list {
                list-style: none;
            }

            .navigation-item {
                margin-bottom: 6px;
            }

            .navigation-link {
                min-height: 48px;
                padding: 0 14px;
                display: flex;
                align-items: center;
                gap: 13px;
                color: var(--text-secondary);
                border-radius: 12px;
                font-size: 14px;
                font-weight: 700;
                transition: 0.2s ease;
            }

                .navigation-link:hover {
                    color: white;
                    background-color: rgba(255, 255, 255, 0.05);
                }

                .navigation-link.active {
                    color: #061108;
                    background-color: var(--primary);
                    box-shadow: 0 9px 28px rgba(30, 215, 96, 0.16);
                }

            .navigation-icon {
                width: 23px;
                text-align: center;
                font-size: 18px;
            }

            .navigation-badge {
                min-width: 25px;
                margin-left: auto;
                padding: 4px 7px;
                color: white;
                background-color: rgba(255, 255, 255, 0.12);
                border-radius: 20px;
                text-align: center;
                font-size: 11px;
            }

            .navigation-link.active .navigation-badge {
                background-color: rgba(0, 0, 0, 0.25);
            }

            .sidebar-footer {
                padding-top: 17px;
                border-top: 1px solid var(--border);
            }

            .user-profile-small {
                padding: 11px;
                display: flex;
                align-items: center;
                gap: 11px;
                background-color: rgba(255, 255, 255, 0.035);
                border-radius: 13px;
            }

            .user-avatar-small {
                width: 39px;
                height: 39px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #08110a;
                background-color: var(--primary);
                border-radius: 50%;
                font-weight: 900;
            }

            .user-profile-info {
                min-width: 0;
                flex: 1;
            }

            .user-name-small {
                overflow: hidden;
                font-size: 13px;
                font-weight: 800;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .user-role {
                margin-top: 3px;
                color: var(--text-secondary);
                font-size: 11px;
            }

            .logout-button {
                width: 34px;
                height: 34px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--text-secondary);
                background: transparent;
                border: none;
                border-radius: 9px;
                transition: 0.2s;
            }

                .logout-button:hover {
                    color: var(--danger);
                    background-color: rgba(255, 92, 92, 0.1);
                }

            /* =========================================
                       ANA İÇERİK
                    ========================================= */

            .main-content {
                width: calc(100% - 265px);
                min-height: 100vh;
                margin-left: 265px;
            }

            .topbar {
                position: sticky;
                top: 0;
                z-index: 900;
                min-height: 78px;
                padding: 16px 34px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                background-color: rgba(8, 11, 9, 0.84);
                border-bottom: 1px solid var(--border);
                backdrop-filter: blur(18px);
            }

            .topbar-left {
                display: flex;
                align-items: center;
                gap: 15px;
            }

            .menu-button {
                width: 42px;
                height: 42px;
                display: none;
                align-items: center;
                justify-content: center;
                color: white;
                background-color: var(--card);
                border: 1px solid var(--border);
                border-radius: 11px;
                font-size: 20px;
            }

            .page-heading h1 {
                font-size: 22px;
                font-weight: 850;
            }

            .page-heading p {
                margin-top: 5px;
                color: var(--text-secondary);
                font-size: 13px;
            }

            .topbar-actions {
                display: flex;
                align-items: center;
                gap: 11px;
            }

            .search-box {
                width: 310px;
                height: 43px;
                padding: 0 15px;
                display: flex;
                align-items: center;
                gap: 10px;
                background-color: var(--card);
                border: 1px solid var(--border);
                border-radius: 12px;
            }

                .search-box span {
                    color: var(--text-secondary);
                }

                .search-box input {
                    width: 100%;
                    color: white;
                    background: transparent;
                    border: none;
                    outline: none;
                    font-size: 13px;
                }

                    .search-box input::placeholder {
                        color: #69716c;
                    }

            .notification-button {
                position: relative;
                width: 43px;
                height: 43px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                background-color: var(--card);
                border: 1px solid var(--border);
                border-radius: 12px;
            }

            .notification-dot {
                position: absolute;
                top: 8px;
                right: 8px;
                width: 7px;
                height: 7px;
                background-color: var(--primary);
                border: 2px solid var(--card);
                border-radius: 50%;
            }

            .dashboard-content {
                padding: 32px 34px 130px;
            }

            /* =========================================
                       KARŞILAMA ALANI
                    ========================================= */

            .welcome-banner {
                position: relative;
                overflow: hidden;
                min-height: 245px;
                padding: 38px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 30px;
                background: linear-gradient( 125deg, rgba(30, 215, 96, 0.23), rgba(18, 23, 19, 0.97) 58% );
                border: 1px solid rgba(30, 215, 96, 0.20);
                border-radius: 22px;
            }

                .welcome-banner::after {
                    content: "♪";
                    position: absolute;
                    right: 40px;
                    bottom: -65px;
                    color: rgba(30, 215, 96, 0.11);
                    font-size: 205px;
                    font-weight: 900;
                    transform: rotate(-12deg);
                }

            .welcome-content {
                position: relative;
                z-index: 1;
                max-width: 660px;
            }

            .welcome-label {
                margin-bottom: 12px;
                color: var(--primary);
                font-size: 12px;
                font-weight: 850;
                letter-spacing: 1.4px;
                text-transform: uppercase;
            }

            .welcome-title {
                margin-bottom: 13px;
                font-size: clamp(31px, 4vw, 52px);
                line-height: 1.08;
            }

            .welcome-description {
                max-width: 620px;
                color: var(--text-secondary);
                font-size: 15px;
                line-height: 1.75;
            }

            .welcome-actions {
                margin-top: 23px;
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 12px;
            }

            .primary-button {
                padding: 13px 20px;
                color: #061108;
                background-color: var(--primary);
                border: none;
                border-radius: 25px;
                font-size: 13px;
                font-weight: 850;
                transition: 0.2s;
            }

                .primary-button:hover {
                    background-color: var(--primary-hover);
                    transform: translateY(-2px);
                }

            .secondary-button {
                padding: 12px 20px;
                color: white;
                background-color: rgba(255, 255, 255, 0.06);
                border: 1px solid var(--border);
                border-radius: 25px;
                font-size: 13px;
                font-weight: 800;
                transition: 0.2s;
            }

                .secondary-button:hover {
                    color: black;
                    background-color: white;
                }

            .featured-cover {
                position: relative;
                z-index: 1;
                width: 165px;
                height: 165px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                color: var(--primary);
                background: radial-gradient( circle at center, #1ed760 0%, #145c2d 34%, #111713 35%, #050706 100% );
                border: 5px solid rgba(255, 255, 255, 0.10);
                border-radius: 22px;
                font-size: 55px;
                box-shadow: 0 22px 55px rgba(0, 0, 0, 0.40);
                transform: rotate(3deg);
            }

            /* =========================================
                       BÖLÜM BAŞLIKLARI
                    ========================================= */

            .section {
                margin-top: 31px;
            }

            .section-header {
                margin-bottom: 17px;
                display: flex;
                align-items: flex-end;
                justify-content: space-between;
                gap: 20px;
            }

            .section-title {
                font-size: 21px;
                font-weight: 850;
            }

            .section-description {
                margin-top: 5px;
                color: var(--text-secondary);
                font-size: 12px;
            }

            .section-link {
                color: var(--primary);
                font-size: 12px;
                font-weight: 800;
            }

            /* =========================================
                       HIZLI İSTATİSTİKLER
                    ========================================= */

            .stat-grid {
                display: grid;
                grid-template-columns: repeat(4, minmax(0, 1fr));
                gap: 18px;
            }

            .stat-card {
                min-height: 125px;
                padding: 20px;
                background-color: var(--card);
                border: 1px solid var(--border);
                border-radius: 17px;
                transition: 0.22s;
            }

                .stat-card:hover {
                    background-color: var(--card-hover);
                    border-color: rgba(30, 215, 96, 0.22);
                    transform: translateY(-3px);
                }

            .stat-icon {
                width: 42px;
                height: 42px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--primary);
                background-color: rgba(30, 215, 96, 0.10);
                border-radius: 12px;
                font-size: 19px;
            }

            .stat-number {
                margin-top: 16px;
                font-size: 25px;
                font-weight: 900;
            }

            .stat-label {
                margin-top: 5px;
                color: var(--text-secondary);
                font-size: 12px;
            }

            /* =========================================
                       ŞARKI KARTLARI
                    ========================================= */

            .song-grid {
                display: grid;
                grid-template-columns: repeat(5, minmax(0, 1fr));
                gap: 18px;
            }

            .song-card {
                position: relative;
                min-width: 0;
                padding: 15px;
                background-color: var(--card);
                border: 1px solid var(--border);
                border-radius: 17px;
                transition: 0.23s ease;
            }

                .song-card:hover {
                    background-color: var(--card-hover);
                    border-color: rgba(30, 215, 96, 0.20);
                    transform: translateY(-5px);
                }

            .song-card-cover {
                position: relative;
                width: 100%;
                aspect-ratio: 1 / 1;
                overflow: hidden;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--primary);
                background: linear-gradient( 135deg, #213928, #0c100e 70% );
                border-radius: 13px;
                font-size: 41px;
            }

            .song-card:nth-child(2) .song-card-cover {
                background: linear-gradient( 135deg, #30252f, #100c10 70% );
            }

            .song-card:nth-child(3) .song-card-cover {
                background: linear-gradient( 135deg, #24303b, #0b0f12 70% );
            }

            .song-card:nth-child(4) .song-card-cover {
                background: linear-gradient( 135deg, #3a3320, #100f0a 70% );
            }

            .song-card:nth-child(5) .song-card-cover {
                background: linear-gradient( 135deg, #293126, #0b0f0b 70% );
            }

            .song-play-button {
                position: absolute;
                right: 11px;
                bottom: 11px;
                width: 46px;
                height: 46px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #071008;
                background-color: var(--primary);
                border: none;
                border-radius: 50%;
                font-size: 17px;
                box-shadow: 0 9px 24px rgba(0, 0, 0, 0.45);
                opacity: 0;
                transform: translateY(8px);
                transition: 0.2s;
            }

            .song-card:hover .song-play-button {
                opacity: 1;
                transform: translateY(0);
            }

            .song-name {
                margin-top: 14px;
                overflow: hidden;
                color: white;
                font-size: 14px;
                font-weight: 800;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .song-artist {
                margin-top: 6px;
                overflow: hidden;
                color: var(--text-secondary);
                font-size: 11px;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .song-card-footer {
                margin-top: 13px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .song-duration {
                color: #6f7872;
                font-size: 10px;
            }

            .like-button {
                color: var(--text-secondary);
                background: transparent;
                border: none;
                font-size: 18px;
                transition: 0.2s;
            }

                .like-button:hover,
                .like-button.liked {
                    color: var(--primary);
                    transform: scale(1.12);
                }

            /* =========================================
                       SANATÇI KARTLARI
                    ========================================= */

            .artist-grid {
                display: grid;
                grid-template-columns: repeat(6, minmax(0, 1fr));
                gap: 18px;
            }

            .artist-card {
                padding: 18px 14px;
                background-color: var(--card);
                border: 1px solid var(--border);
                border-radius: 17px;
                text-align: center;
                transition: 0.22s;
            }

                .artist-card:hover {
                    background-color: var(--card-hover);
                    border-color: rgba(30, 215, 96, 0.20);
                    transform: translateY(-4px);
                }

            .artist-image {
                width: 105px;
                height: 105px;
                margin: 0 auto;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #071008;
                background: radial-gradient( circle at 35% 30%, #5af08f, var(--primary) 45%, #0c682e );
                border: 4px solid rgba(255, 255, 255, 0.08);
                border-radius: 50%;
                font-size: 31px;
                font-weight: 900;
            }

            .artist-card:nth-child(2) .artist-image {
                background: radial-gradient( circle at 35% 30%, #87baff, #4e86cc 45%, #203f68 );
            }

            .artist-card:nth-child(3) .artist-image {
                background: radial-gradient( circle at 35% 30%, #ffc76b, #d98b2f 45%, #684016 );
            }

            .artist-card:nth-child(4) .artist-image {
                background: radial-gradient( circle at 35% 30%, #ff91b6, #c94975 45%, #68233a );
            }

            .artist-card:nth-child(5) .artist-image {
                background: radial-gradient( circle at 35% 30%, #b59aff, #7657c6 45%, #392668 );
            }

            .artist-card:nth-child(6) .artist-image {
                background: radial-gradient( circle at 35% 30%, #8af0dc, #3ea38f 45%, #205d51 );
            }

            .artist-name {
                margin-top: 14px;
                overflow: hidden;
                font-size: 13px;
                font-weight: 850;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .artist-label {
                margin-top: 5px;
                color: var(--text-secondary);
                font-size: 10px;
            }

            .follow-button {
                margin-top: 13px;
                padding: 8px 14px;
                color: white;
                background-color: transparent;
                border: 1px solid rgba(255, 255, 255, 0.18);
                border-radius: 20px;
                font-size: 10px;
                font-weight: 800;
                transition: 0.2s;
            }

                .follow-button:hover {
                    color: #071008;
                    background-color: var(--primary);
                    border-color: var(--primary);
                }

            /* =========================================
                       SON DİNLENENLER TABLOSU
                    ========================================= */

            .panel {
                background-color: var(--card);
                border: 1px solid var(--border);
                border-radius: 19px;
            }

            .panel-header {
                min-height: 69px;
                padding: 18px 21px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                border-bottom: 1px solid var(--border);
            }

            .table-wrapper {
                overflow-x: auto;
            }

            .data-table {
                width: 100%;
                border-collapse: collapse;
            }

                .data-table th,
                .data-table td {
                    padding: 15px 18px;
                    border-bottom: 1px solid var(--border);
                    text-align: left;
                    white-space: nowrap;
                }

                .data-table th {
                    color: #687169;
                    font-size: 10px;
                    font-weight: 850;
                    letter-spacing: 0.8px;
                    text-transform: uppercase;
                }

                .data-table td {
                    color: #d8ded9;
                    font-size: 12px;
                }

                .data-table tbody tr {
                    transition: 0.2s;
                }

                    .data-table tbody tr:hover {
                        background-color: rgba(255, 255, 255, 0.025);
                    }

                    .data-table tbody tr:last-child td {
                        border-bottom: none;
                    }

            .table-song {
                display: flex;
                align-items: center;
                gap: 11px;
            }

            .table-cover {
                width: 42px;
                height: 42px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                color: var(--primary);
                background: linear-gradient( 135deg, #1d3324, #0c110e );
                border-radius: 11px;
                font-size: 17px;
            }

            .cell-title {
                color: white;
                font-size: 12px;
                font-weight: 750;
            }

            .cell-subtitle {
                margin-top: 3px;
                color: var(--text-secondary);
                font-size: 10px;
            }

            .table-play-button {
                width: 34px;
                height: 34px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #071008;
                background-color: var(--primary);
                border: none;
                border-radius: 50%;
                font-size: 12px;
                transition: 0.2s;
            }

                .table-play-button:hover {
                    background-color: var(--primary-hover);
                    transform: scale(1.07);
                }

            /* =========================================
                       ALT MÜZİK OYNATICI
                    ========================================= */

            .music-player {
                position: fixed;
                right: 0;
                bottom: 0;
                left: 265px;
                z-index: 950;
                min-height: 92px;
                padding: 14px 28px;
                display: grid;
                grid-template-columns: minmax(220px, 1fr) minmax(310px, 1.4fr) minmax(180px, 1fr);
                align-items: center;
                gap: 25px;
                background-color: rgba(12, 16, 13, 0.97);
                border-top: 1px solid var(--border);
                backdrop-filter: blur(18px);
            }

            .playing-song {
                min-width: 0;
                display: flex;
                align-items: center;
                gap: 13px;
            }

            .playing-cover {
                width: 57px;
                height: 57px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                color: var(--primary);
                background: linear-gradient( 135deg, #213a29, #090d0a );
                border-radius: 11px;
                font-size: 21px;
            }

            .playing-info {
                min-width: 0;
            }

            .playing-name {
                overflow: hidden;
                color: white;
                font-size: 12px;
                font-weight: 800;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .playing-artist {
                margin-top: 5px;
                overflow: hidden;
                color: var(--text-secondary);
                font-size: 10px;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .player-center {
                display: flex;
                align-items: center;
                flex-direction: column;
                gap: 9px;
            }

            .player-controls {
                display: flex;
                align-items: center;
                gap: 19px;
            }

            .player-control {
                color: var(--text-secondary);
                background: transparent;
                border: none;
                font-size: 17px;
                transition: 0.2s;
            }

                .player-control:hover {
                    color: white;
                }

            .main-play-button {
                width: 39px;
                height: 39px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #071008;
                background-color: white;
                border: none;
                border-radius: 50%;
                font-size: 14px;
                transition: 0.2s;
            }

                .main-play-button:hover {
                    background-color: var(--primary);
                    transform: scale(1.05);
                }

            .progress-area {
                width: 100%;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .progress-time {
                width: 30px;
                color: #6f7872;
                font-size: 9px;
            }

            .progress-line {
                position: relative;
                height: 4px;
                overflow: hidden;
                flex: 1;
                background-color: #303731;
                border-radius: 10px;
            }

            .progress-value {
                width: 38%;
                height: 100%;
                background-color: var(--primary);
                border-radius: 10px;
            }

            .player-right {
                display: flex;
                align-items: center;
                justify-content: flex-end;
                gap: 12px;
            }

            .volume-line {
                width: 95px;
                height: 4px;
                overflow: hidden;
                background-color: #303731;
                border-radius: 10px;
            }

            .volume-value {
                width: 70%;
                height: 100%;
                background-color: white;
                border-radius: 10px;
            }

            /* =========================================
                       MOBİL UYUMLULUK
                    ========================================= */

            .sidebar-overlay {
                position: fixed;
                inset: 0;
                z-index: 960;
                display: none;
                background-color: rgba(0, 0, 0, 0.65);
            }

            @@media (max-width: 1250px) {
                .song-grid {
                    grid-template-columns: repeat(4, minmax(0, 1fr));
                }

                .artist-grid {
                    grid-template-columns: repeat(3, minmax(0, 1fr));
                }
            }

            @@media (max-width: 1050px) {
                .stat-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }

                .song-grid {
                    grid-template-columns: repeat(3, minmax(0, 1fr));
                }
            }

            @@media (max-width: 900px) {
                .sidebar {
                    transform: translateX(-100%);
                }

                    .sidebar.open {
                        transform: translateX(0);
                    }

                .sidebar-overlay.open {
                    display: block;
                }

                .main-content {
                    width: 100%;
                    margin-left: 0;
                }

                .music-player {
                    left: 0;
                }

                .menu-button {
                    display: flex;
                }

                .search-box {
                    width: 230px;
                }
            }

            @@media (max-width: 720px) {
                .topbar {
                    padding: 14px 17px;
                }

                .page-heading p {
                    display: none;
                }

                .search-box {
                    display: none;
                }

                .dashboard-content {
                    padding: 20px 16px 160px;
                }

                .welcome-banner {
                    padding: 27px;
                    align-items: flex-start;
                    flex-direction: column;
                }

                .featured-cover {
                    width: 125px;
                    height: 125px;
                    font-size: 43px;
                    transform: none;
                }

                .song-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }

                .artist-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }

                .music-player {
                    min-height: 128px;
                    padding: 12px 16px;
                    grid-template-columns: 1fr auto;
                }

                .player-center {
                    grid-column: 1 / -1;
                    grid-row: 2;
                }

                .player-right {
                    display: none;
                }
            }

            @@media (max-width: 480px) {
                .stat-grid {
                    grid-template-columns: 1fr;
                }

                .song-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                    gap: 11px;
                }

                .song-card {
                    padding: 11px;
                }

                .artist-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                    gap: 11px;
                }

                .artist-image {
                    width: 82px;
                    height: 82px;
                }

                .welcome-actions {
                    align-items: stretch;
                    flex-direction: column;
                }

                .primary-button,
                .secondary-button {
                    width: 100%;
                    text-align: center;
                }
            }
    </style>
</head>

<body>

    <div class="user-layout">

        <!-- SOL MENÜ -->
        <aside class="sidebar" id="sidebar">

            <a href="/" class="brand">

                <div class="brand-icon">
                    ♪
                </div>

                <div>
                    <span class="brand-name">
                        MusicProject
                    </span>

                    <span class="brand-panel">
                        Müzik dünyan
                    </span>
                </div>

            </a>

            <nav class="navigation">

                <p class="navigation-title">
                    Keşfet
                </p>

                <ul class="navigation-list">

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link active">

                            <span class="navigation-icon">
                                ▦
                            </span>

                            Ana Sayfa
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ♫
                            </span>

                            Şarkıları Keşfet
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ★
                            </span>

                            Sanatçılar
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ▤
                            </span>

                            Türler
                        </a>
                    </li>

                </ul>

                <p class="navigation-title"
                   style="margin-top: 27px;">
                    Kitaplığım
                </p>

                <ul class="navigation-list">

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ♥
                            </span>

                            Beğendiğim Şarkılar

                            <span class="navigation-badge">
                                24
                            </span>
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ◷
                            </span>

                            Son Dinlediklerim
                        </a>
                    </li>

                    <li class="navigation-item">
                        <a href="#"
                           class="navigation-link">

                            <span class="navigation-icon">
                                ⚙
                            </span>

                            Hesap Ayarları
                        </a>
                    </li>

                </ul>

            </nav>

            <div class="sidebar-footer">

                <div class="user-profile-small">

                    <div class="user-avatar-small">
                        @(string.IsNullOrWhiteSpace(Model.Username)
                            ? "?"
                            : Model.Username.Substring(0, 1).ToUpper())
                    </div>

                    <div class="user-profile-info">

                        <div class="user-name-small">
                            @Model.Username
                        </div>

                        <div class="user-role">
                            @Model.Role
                        </div>

                    </div>

                    <a href="/Auth/Logout"
                       class="logout-button"
                       title="Çıkış Yap">
                        ↪
                    </a>

                </div>

            </div>

        </aside>

        <div class="sidebar-overlay"
             id="sidebarOverlay">
        </div>

        <!-- ANA İÇERİK -->
        <main class="main-content">

            <header class="topbar">

                <div class="topbar-left">

                    <button type="button"
                            class="menu-button"
                            id="menuButton">
                        ☰
                    </button>

                    <div class="page-heading">

                        <h1>
                            Ana Sayfa
                        </h1>

                        <p>
                            Sevdiğin müzikleri keşfet ve dinlemeye başla.
                        </p>

                    </div>

                </div>

                <div class="topbar-actions">

                    <div class="search-box">

                        <span>
                            ⌕
                        </span>

                        <input type="text"
                               placeholder="Şarkı, sanatçı veya albüm ara..." />

                    </div>

                    <button type="button"
                            class="notification-button"
                            title="Bildirimler">

                        ♢

                        <span class="notification-dot"></span>

                    </button>

                </div>

            </header>

            <div class="dashboard-content">

                <!-- KARŞILAMA ALANI -->
                <section class="welcome-banner">

                    <div class="welcome-content">

                        <p class="welcome-label">
                            Senin için seçildi
                        </p>

                        <h2 class="welcome-title">
                            Tekrar hoş geldin, @Model.Username.
                        </h2>

                        <p class="welcome-description">
                            Yeni yayınlanan şarkıları keşfet, favori
                            sanatçılarını takip et ve beğendiğin müzikleri
                            kendi kitaplığında sakla.
                        </p>

                        <div class="welcome-actions">

                            <button type="button"
                                    class="primary-button">
                                ▶ Dinlemeye Başla
                            </button>

                            <a href="#"
                               class="secondary-button">
                                Şarkıları Keşfet
                            </a>

                        </div>

                    </div>

                    <div class="featured-cover">
                        ♪
                    </div>

                </section>

                <!-- KULLANICI İSTATİSTİKLERİ -->
                <section class="section">

                    <div class="section-header">

                        <div>
                            <h3 class="section-title">
                                Müzik özetin
                            </h3>

                            <p class="section-description">
                                Hesabındaki müzik etkinliklerinin kısa özeti
                            </p>
                        </div>

                    </div>

                    <div class="stat-grid">

                        <article class="stat-card">

                            <div class="stat-icon">
                                ▶
                            </div>

                            <div class="stat-number">
                                148
                            </div>

                            <div class="stat-label">
                                Dinlediğin şarkı
                            </div>

                        </article>

                        <article class="stat-card">

                            <div class="stat-icon">
                                ♥
                            </div>

                            <div class="stat-number">
                                24
                            </div>

                            <div class="stat-label">
                                Beğendiğin şarkı
                            </div>

                        </article>

                        <article class="stat-card">

                            <div class="stat-icon">
                                ★
                            </div>

                            <div class="stat-number">
                                8
                            </div>

                            <div class="stat-label">
                                Takip ettiğin sanatçı
                            </div>

                        </article>

                        <article class="stat-card">

                            <div class="stat-icon">
                                ◷
                            </div>

                            <div class="stat-number">
                                12 saat
                            </div>

                            <div class="stat-label">
                                Toplam dinleme süresi
                            </div>

                        </article>

                    </div>

                </section>

                <!-- POPÜLER ŞARKILAR -->
                <section class="section">

                    <div class="section-header">

                        <div>
                            <h3 class="section-title">
                                Popüler şarkılar
                            </h3>

                            <p class="section-description">
                                Platformda en çok dinlenen şarkılar
                            </p>
                        </div>

                        <a href="#"
                           class="section-link">
                            Tümünü Gör
                        </a>

                    </div>

                    @if (Model.PopularSongs.Any())
                    {
                        <div class="song-grid">

                            @foreach (var song in Model.PopularSongs)
                            {
                                <article class="song-card">

                                    <div class="song-card-cover">

                                        ♪

                                        <button type="button"
                                                class="song-play-button"
                                                data-song-id="@song.Id"
                                                title="@song.Title şarkısını oynat">
                                            ▶
                                        </button>

                                    </div>

                                    <h4 class="song-name">
                                        @song.Title
                                    </h4>

                                    <p class="song-artist">
                                        @(song.Album?.Name ?? "Albüm bilgisi yok")
                                    </p>

                                    <div class="song-card-footer">

                                        <span class="song-duration">
                                            @(song.SongStat?.TotalStreams ?? 0) dinlenme
                                        </span>

                                        <button type="button"
                                                class="like-button"
                                                data-song-id="@song.Id"
                                                title="Şarkıyı beğen">
                                            ♡
                                        </button>

                                    </div>

                                </article>
                            }

                        </div>
                    }
                    else
                    {
                        <div class="panel"
                             style="padding: 24px;">

                            <p class="section-description"
                               style="margin: 0;">
                                Henüz gösterilecek popüler şarkı bulunmuyor.
                            </p>

                        </div>
                    }

                </section>

                <!-- SANATÇILAR -->
                <section class="section">

                    <div class="section-header">

                        <div>
                            <h3 class="section-title">
                                Keşfedebileceğin sanatçılar
                            </h3>

                            <p class="section-description">
                                Yeni sanatçılarla ve yeni müziklerle tanış
                            </p>
                        </div>

                        <a href="#"
                           class="section-link">
                            Tüm Sanatçılar
                        </a>

                    </div>

                    @if (Model.Artists.Any())
                    {
                        <div class="artist-grid">

                            @foreach (var artist in Model.Artists.Take(6))
                            {
                                <article class="artist-card">

                                    <div class="artist-image">
                                        @(string.IsNullOrWhiteSpace(artist.Name)
                                            ? "?"
                                            : artist.Name.Substring(0, 1).ToUpper())
                                    </div>

                                    <h4 class="artist-name">
                                        @artist.Name
                                    </h4>

                                    <p class="artist-label">
                                        Sanatçı
                                    </p>

                                    <button type="button"
                                            class="follow-button"
                                            data-artist-id="@artist.Id">
                                        Takip Et
                                    </button>

                                </article>
                            }

                        </div>
                    }
                    else
                    {
                        <div class="panel"
                             style="padding: 24px;">

                            <p class="section-description"
                               style="margin: 0;">
                                Henüz gösterilecek sanatçı bulunmuyor.
                            </p>

                        </div>
                    }

                </section>

                <!-- SON DİNLENENLER -->
                <section class="section panel">

                    <div class="panel-header">

                        <div>
                            <h3 class="section-title">
                                Son dinlediklerin
                            </h3>

                            <p class="section-description">
                                Kaldığın yerden dinlemeye devam et
                            </p>
                        </div>

                        <a href="#"
                           class="section-link">
                            Geçmişi Gör
                        </a>

                    </div>

                    <div class="table-wrapper">

                        <table class="data-table">

                            <thead>
                                <tr>
                                    <th>Şarkı</th>
                                    <th>Albüm</th>
                                    <th>Tür</th>
                                    <th>Süre</th>
                                    <th>Dinle</th>
                                </tr>
                            </thead>

                            <tbody>

                                <tr>
                                    <td>

                                        <div class="table-song">

                                            <div class="table-cover">
                                                ♪
                                            </div>

                                            <div>
                                                <div class="cell-title">
                                                    Gece Yolculuğu
                                                </div>

                                                <div class="cell-subtitle">
                                                    Elif Kaya
                                                </div>
                                            </div>

                                        </div>

                                    </td>

                                    <td>
                                        Bağımsız Single
                                    </td>

                                    <td>
                                        Pop
                                    </td>

                                    <td>
                                        3:42
                                    </td>

                                    <td>

                                        <button type="button"
                                                class="table-play-button">
                                            ▶
                                        </button>

                                    </td>
                                </tr>

                                <tr>
                                    <td>

                                        <div class="table-song">

                                            <div class="table-cover">
                                                ♪
                                            </div>

                                            <div>
                                                <div class="cell-title">
                                                    Son Durak
                                                </div>

                                                <div class="cell-subtitle">
                                                    Atlas
                                                </div>
                                            </div>

                                        </div>

                                    </td>

                                    <td>
                                        Şehir Işıkları
                                    </td>

                                    <td>
                                        Alternatif
                                    </td>

                                    <td>
                                        4:05
                                    </td>

                                    <td>

                                        <button type="button"
                                                class="table-play-button">
                                            ▶
                                        </button>

                                    </td>
                                </tr>

                                <tr>
                                    <td>

                                        <div class="table-song">

                                            <div class="table-cover">
                                                ♪
                                            </div>

                                            <div>
                                                <div class="cell-title">
                                                    Sessiz Şehir
                                                </div>

                                                <div class="cell-subtitle">
                                                    Mavi
                                                </div>
                                            </div>

                                        </div>

                                    </td>

                                    <td>
                                        Gecenin İçinden
                                    </td>

                                    <td>
                                        Indie
                                    </td>

                                    <td>
                                        3:18
                                    </td>

                                    <td>

                                        <button type="button"
                                                class="table-play-button">
                                            ▶
                                        </button>

                                    </td>
                                </tr>

                            </tbody>

                        </table>

                    </div>

                </section>

            </div>

        </main>

        <!-- ALT MÜZİK OYNATICI -->
        <div class="music-player">

            <div class="playing-song">

                <div class="playing-cover">
                    ♪
                </div>

                <div class="playing-info">

                    <div class="playing-name">
                        Gece Yolculuğu
                    </div>

                    <div class="playing-artist">
                        Elif Kaya
                    </div>

                </div>

                <button type="button"
                        class="like-button liked">
                    ♥
                </button>

            </div>

            <div class="player-center">

                <div class="player-controls">

                    <button type="button"
                            class="player-control"
                            title="Karıştır">
                        ⤨
                    </button>

                    <button type="button"
                            class="player-control"
                            title="Önceki">
                        ◀
                    </button>

                    <button type="button"
                            class="main-play-button"
                            id="mainPlayButton"
                            title="Oynat">
                        ▶
                    </button>

                    <button type="button"
                            class="player-control"
                            title="Sonraki">
                        ▶
                    </button>

                    <button type="button"
                            class="player-control"
                            title="Tekrarla">
                        ↻
                    </button>

                </div>

                <div class="progress-area">

                    <span class="progress-time">
                        1:24
                    </span>

                    <div class="progress-line">
                        <div class="progress-value"></div>
                    </div>

                    <span class="progress-time">
                        3:42
                    </span>

                </div>

            </div>

            <div class="player-right">

                <span>
                    🔊
                </span>

                <div class="volume-line">
                    <div class="volume-value"></div>
                </div>

            </div>

        </div>

    </div>

    <script>
            const menuButton = document.getElementById("menuButton");
            const sidebar = document.getElementById("sidebar");
            const sidebarOverlay = document.getElementById("sidebarOverlay");
            const mainPlayButton = document.getElementById("mainPlayButton");

            function openSidebar() {
                sidebar.classList.add("open");
                sidebarOverlay.classList.add("open");
            }

            function closeSidebar() {
                sidebar.classList.remove("open");
                sidebarOverlay.classList.remove("open");
            }

            if (menuButton && sidebar && sidebarOverlay) {
                menuButton.addEventListener("click", openSidebar);
                sidebarOverlay.addEventListener("click", closeSidebar);
            }

            if (mainPlayButton) {
                mainPlayButton.addEventListener("click", function() {
                if (mainPlayButton.textContent.trim() === "▶") {
                    mainPlayButton.textContent = "Ⅱ";
                    mainPlayButton.title = "Duraklat";
                }
                else {
                    mainPlayButton.textContent = "▶";
                    mainPlayButton.title = "Oynat";
                }
                });
            }

            const likeButtons = document.querySelectorAll(".like-button");

            likeButtons.forEach(function(button) {
                button.addEventListener("click", function() {
                    button.classList.toggle("liked");

                    if (button.classList.contains("liked")) {
                        button.textContent = "♥";
                    }
                    else {
                        button.textContent = "♡";
                    }
                });
            });
    </script>

</body>
</html>