@model MusicProject.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MusicProject</title>

    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: Arial, Helvetica, sans-serif;
                color: white;
                background: radial-gradient( circle at top left, rgba(29, 185, 84, 0.25), transparent 35% ), linear-gradient( 135deg, #080808, #121212, #1c1c1c );
            }

            .navbar {
                width: 100%;
                height: 80px;
                padding: 0 7%;
                display: flex;
                align-items: center;
                justify-content: space-between;
                background-color: rgba(0, 0, 0, 0.55);
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                backdrop-filter: blur(10px);
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                color: white;
                text-decoration: none;
            }

            .logo-icon {
                width: 42px;
                height: 42px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                background-color: #1db954;
                color: black;
                font-size: 23px;
                font-weight: bold;
            }

            .logo-text {
                font-size: 24px;
                font-weight: bold;
            }

            .home-link {
                padding: 11px 22px;
                color: white;
                text-decoration: none;
                border: 1px solid rgba(255, 255, 255, 0.35);
                border-radius: 25px;
                font-weight: bold;
                transition: 0.2s;
            }

                .home-link:hover {
                    color: black;
                    background-color: white;
                }

            .page-container {
                min-height: calc(100vh - 80px);
                padding: 50px 20px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .register-card {
                width: 100%;
                max-width: 480px;
                padding: 42px;
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 24px;
                background-color: rgba(24, 24, 24, 0.9);
                box-shadow: 0 25px 70px rgba(0, 0, 0, 0.45);
                backdrop-filter: blur(15px);
            }

            .card-icon {
                width: 70px;
                height: 70px;
                margin: 0 auto 22px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                color: black;
                background-color: #1db954;
                font-size: 32px;
                font-weight: bold;
            }

            .title {
                margin-bottom: 10px;
                text-align: center;
                font-size: 34px;
            }

            .description {
                margin-bottom: 30px;
                color: #aaaaaa;
                text-align: center;
                line-height: 1.6;
            }

            .form-group {
                margin-bottom: 18px;
            }

            .form-label {
                display: block;
                margin-bottom: 9px;
                color: #eeeeee;
                font-size: 15px;
                font-weight: bold;
            }

            .form-control {
                width: 100%;
                padding: 14px 15px;
                color: white;
                background-color: #242424;
                border: 1px solid #3d3d3d;
                border-radius: 10px;
                outline: none;
                font-size: 15px;
                transition: 0.2s;
            }

                .form-control::placeholder {
                    color: #777777;
                }

                .form-control:focus {
                    border-color: #1db954;
                    box-shadow: 0 0 0 3px rgba(29, 185, 84, 0.13);
                }

            .validation-error {
                display: block;
                margin-top: 7px;
                color: #ff6b6b;
                font-size: 13px;
            }

            .validation-summary {
                margin-bottom: 20px;
                padding: 12px 15px;
                color: #ff8d8d;
                background-color: rgba(255, 70, 70, 0.1);
                border: 1px solid rgba(255, 70, 70, 0.2);
                border-radius: 10px;
            }

                .validation-summary:empty {
                    display: none;
                }

            .register-button {
                width: 100%;
                margin-top: 5px;
                padding: 15px;
                border: none;
                border-radius: 30px;
                color: black;
                background-color: #1db954;
                font-size: 16px;
                font-weight: bold;
                cursor: pointer;
                transition: 0.2s;
            }

                .register-button:hover {
                    background-color: #25d366;
                    transform: translateY(-2px);
                }

            .login-area {
                margin-top: 26px;
                color: #aaaaaa;
                text-align: center;
            }

            .login-link {
                margin-left: 5px;
                color: #1db954;
                text-decoration: none;
                font-weight: bold;
            }

                .login-link:hover {
                    text-decoration: underline;
                }

            @@media (max-width: 550px) {
                .navbar {
                    height: auto;
                    padding-top: 18px;
                    padding-bottom: 18px;
                    flex-direction: column;
                    gap: 18px;
                }

                .page-container {
                    min-height: calc(100vh - 130px);
                    padding: 35px 15px;
                }

                .register-card {
                    padding: 30px 22px;
                }

                .title {
                    font-size: 29px;
                }
            }
    </style>
</head>

<body>

    <nav class="navbar">

        <a href="/" class="logo">

            <div class="logo-icon">
                ♪
            </div>

            <span class="logo-text">
                MusicProject
            </span>

        </a>

        <a href="/" class="home-link">
            Ana Sayfa
        </a>

    </nav>

    <main class="page-container">

        <div class="register-card">

            <div class="card-icon">
                ♫
            </div>

            <h1 class="title">
                Müzik dünyana katıl
            </h1>

            <p class="description">
                Favori şarkılarını keşfetmek için ücretsiz hesabını oluştur.
            </p>

            <form action="/Auth/Register" method="post">

                @Html.AntiForgeryToken()

                @* // DEĞİŞİKLİK: E-posta zaten kayıtlı gibi genel hatalar için tasarımlı alan eklendi. *@
                <div asp-validation-summary="ModelOnly"
                     class="validation-summary">
                </div>

                <div class="form-group">

                    <label asp-for="FullName"
                           class="form-label">
                    </label>

                    <input asp-for="FullName"
                           class="form-control"
                           placeholder="Adınızı ve soyadınızı girin" />

                    <span asp-validation-for="FullName"
                          class="validation-error">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="Email"
                           class="form-label">
                    </label>

                    <input asp-for="Email"
                           class="form-control"
                           type="email"
                           placeholder="E-posta adresinizi girin" />

                    <span asp-validation-for="Email"
                          class="validation-error">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="Password"
                           class="form-label">
                    </label>

                    <input asp-for="Password"
                           class="form-control"
                           type="password"
                           placeholder="En az 6 karakterli şifre girin" />

                    <span asp-validation-for="Password"
                          class="validation-error">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="ConfirmPassword"
                           class="form-label">
                    </label>

                    <input asp-for="ConfirmPassword"
                           class="form-control"
                           type="password"
                           placeholder="Şifrenizi tekrar girin" />

                    <span asp-validation-for="ConfirmPassword"
                          class="validation-error">
                    </span>

                </div>

                <button type="submit"
                        class="register-button">
                    Hesap Oluştur
                </button>

            </form>

            <div class="login-area">

                Zaten hesabın var mı?

                <a href="/Auth/Login"
                   class="login-link">
                    Giriş Yap
                </a>

            </div>

        </div>

    </main>

</body>
</html>