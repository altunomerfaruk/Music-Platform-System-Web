@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MusicProject</title>

    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: Arial, Helvetica, sans-serif;
                color: white;
                background: radial-gradient( circle at top left, rgba(29, 185, 84, 0.25), transparent 35% ), linear-gradient( 135deg, #080808, #121212, #1c1c1c );
            }

            .navbar {
                width: 100%;
                height: 80px;
                padding: 0 7%;
                display: flex;
                align-items: center;
                justify-content: space-between;
                background-color: rgba(0, 0, 0, 0.55);
                backdrop-filter: blur(10px);
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 12px;
                color: white;
                text-decoration: none;
            }

            .logo-icon {
                width: 42px;
                height: 42px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                background-color: #1db954;
                font-size: 23px;
            }

            .logo-text {
                font-size: 24px;
                font-weight: bold;
                letter-spacing: 0.5px;
            }

            .navbar-links {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .navbar-link {
                color: #d5d5d5;
                text-decoration: none;
                font-size: 15px;
                font-weight: bold;
                transition: 0.2s;
            }

                .navbar-link:hover {
                    color: white;
                }

            .login-button {
                padding: 11px 22px;
                color: white;
                text-decoration: none;
                border: 1px solid rgba(255, 255, 255, 0.4);
                border-radius: 25px;
                font-weight: bold;
                transition: 0.2s;
            }

                .login-button:hover {
                    background-color: white;
                    color: black;
                }

            .register-button {
                padding: 12px 23px;
                color: black;
                text-decoration: none;
                background-color: #1db954;
                border-radius: 25px;
                font-weight: bold;
                transition: 0.2s;
            }

                .register-button:hover {
                    background-color: #25d366;
                    transform: translateY(-2px);
                }

            .hero-section {
                min-height: 570px;
                padding: 90px 8% 70px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 60px;
            }

            .hero-content {
                width: 55%;
            }

            .hero-small-title {
                margin-bottom: 17px;
                color: #1db954;
                font-size: 16px;
                font-weight: bold;
                letter-spacing: 2px;
                text-transform: uppercase;
            }

            .hero-title {
                max-width: 720px;
                margin-bottom: 23px;
                font-size: 65px;
                line-height: 1.08;
            }

                .hero-title span {
                    color: #1db954;
                }

            .hero-description {
                max-width: 620px;
                margin-bottom: 35px;
                color: #bdbdbd;
                font-size: 19px;
                line-height: 1.7;
            }

            .hero-buttons {
                display: flex;
                align-items: center;
                gap: 15px;
            }

            .hero-primary-button {
                padding: 15px 29px;
                color: black;
                text-decoration: none;
                background-color: #1db954;
                border-radius: 30px;
                font-weight: bold;
                transition: 0.2s;
            }

                .hero-primary-button:hover {
                    background-color: #25d366;
                    transform: translateY(-2px);
                }

            .hero-secondary-button {
                padding: 14px 29px;
                color: white;
                text-decoration: none;
                border: 1px solid rgba(255, 255, 255, 0.35);
                border-radius: 30px;
                font-weight: bold;
                transition: 0.2s;
            }

                .hero-secondary-button:hover {
                    color: black;
                    background-color: white;
                }

            .music-card {
                width: 360px;
                padding: 25px;
                border: 1px solid rgba(255, 255, 255, 0.12);
                border-radius: 25px;
                background-color: rgba(255, 255, 255, 0.07);
                box-shadow: 0 25px 70px rgba(0, 0, 0, 0.45);
                backdrop-filter: blur(15px);
                transform: rotate(3deg);
            }

            .album-image {
                width: 100%;
                height: 285px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 18px;
                background: radial-gradient( circle at center, #1db954, #0d5f2c 45%, #090909 46% );
                font-size: 85px;
            }

            .song-information {
                margin-top: 22px;
            }

            .song-name {
                margin-bottom: 7px;
                font-size: 22px;
            }

            .artist-name {
                color: #a8a8a8;
                font-size: 15px;
            }

            .player-controls {
                margin-top: 24px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 27px;
            }

            .control-button {
                border: none;
                color: white;
                background: transparent;
                font-size: 21px;
                cursor: pointer;
            }

            .play-button {
                width: 55px;
                height: 55px;
                border: none;
                border-radius: 50%;
                color: black;
                background-color: #1db954;
                font-size: 21px;
                cursor: pointer;
            }

            .features-section {
                padding: 70px 8% 90px;
                background-color: rgba(0, 0, 0, 0.25);
            }

            .section-title {
                margin-bottom: 12px;
                text-align: center;
                font-size: 38px;
            }

            .section-description {
                margin-bottom: 42px;
                color: #aaaaaa;
                text-align: center;
                font-size: 17px;
            }

            .features-container {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 25px;
            }

            .feature-card {
                padding: 32px;
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 18px;
                background-color: #181818;
                transition: 0.25s;
            }

                .feature-card:hover {
                    background-color: #232323;
                    transform: translateY(-7px);
                }

            .feature-icon {
                width: 55px;
                height: 55px;
                margin-bottom: 22px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 15px;
                color: black;
                background-color: #1db954;
                font-size: 27px;
            }

            .feature-title {
                margin-bottom: 12px;
                font-size: 21px;
            }

            .feature-description {
                color: #aaaaaa;
                line-height: 1.7;
            }

            .footer {
                padding: 28px 8%;
                display: flex;
                align-items: center;
                justify-content: space-between;
                color: #898989;
                background-color: #080808;
                border-top: 1px solid rgba(255, 255, 255, 0.07);
                font-size: 14px;
            }

            @@media (max-width: 950px) {
                .hero-section {
                    flex-direction: column;
                    text-align: center;
                }

                .hero-content {
                    width: 100%;
                }

                .hero-description {
                    margin-left: auto;
                    margin-right: auto;
                }

                .hero-buttons {
                    justify-content: center;
                }

                .hero-title {
                    font-size: 50px;
                }

                .music-card {
                    transform: none;
                }

                .features-container {
                    grid-template-columns: 1fr;
                }
            }

            @@media (max-width: 650px) {
                .navbar {
                    height: auto;
                    padding-top: 18px;
                    padding-bottom: 18px;
                    flex-direction: column;
                    gap: 20px;
                }

                .navbar-links {
                    flex-wrap: wrap;
                    justify-content: center;
                }

                .hero-section {
                    padding-top: 60px;
                }

                .hero-title {
                    font-size: 39px;
                }

                .hero-description {
                    font-size: 17px;
                }

                .hero-buttons {
                    flex-direction: column;
                }

                .hero-primary-button,
                .hero-secondary-button {
                    width: 100%;
                    text-align: center;
                }

                .music-card {
                    width: 100%;
                    max-width: 360px;
                }

                .footer {
                    flex-direction: column;
                    gap: 10px;
                    text-align: center;
                }
            }
    </style>
</head>

<body>

    <nav class="navbar">

        <a href="/" class="logo">
            <div class="logo-icon">♪</div>

            <span class="logo-text">
                MusicProject
            </span>
        </a>

        <div class="navbar-links">

            <a href="/" class="navbar-link">
                Ana Sayfa
            </a>

            <a href="/Artist/Index" class="navbar-link">
                Sanatçılar
            </a>

            <a href="/Song/Index" class="navbar-link">
                Şarkılar
            </a>

            <a href="/Auth/Login" class="login-button">
                Giriş Yap
            </a>

            <a href="/Auth/Register" class="register-button">
                Kayıt Ol
            </a>

        </div>

    </nav>

    <main>

        <section class="hero-section">

            <div class="hero-content">

                <p class="hero-small-title">
                    Müziğin yeni adresi
                </p>

                <h1 class="hero-title">
                    Sevdiğin müzikleri
                    <span>keşfet.</span>
                </h1>

                <p class="hero-description">
                    Favori sanatçılarını takip et, yeni şarkılar keşfet
                    ve kendi müzik dünyanı oluştur.
                </p>

                <div class="hero-buttons">

                    <a href="/Auth/Register"
                       class="hero-primary-button">
                        Ücretsiz Kayıt Ol
                    </a>

                    <a href="/Artist/Index"
                       class="hero-secondary-button">
                        Sanatçıları Keşfet
                    </a>

                </div>

            </div>

            <div class="music-card">

                <div class="album-image">
                    ♪
                </div>

                <div class="song-information">

                    <h3 class="song-name">
                        Müziği Hisset
                    </h3>

                    <p class="artist-name">
                        MusicProject
                    </p>

                </div>

                <div class="player-controls">

                    <button class="control-button"
                            type="button">
                        ◀
                    </button>

                    <button class="play-button"
                            type="button">
                        ▶
                    </button>

                    <button class="control-button"
                            type="button">
                        ▶
                    </button>

                </div>

            </div>

        </section>

        <section class="features-section">

            <h2 class="section-title">
                MusicProject ile neler yapabilirsin?
            </h2>

            <p class="section-description">
                Müziği keşfetmenin daha kolay ve keyifli yolu.
            </p>

            <div class="features-container">

                <div class="feature-card">

                    <div class="feature-icon">
                        ♫
                    </div>

                    <h3 class="feature-title">
                        Yeni şarkılar keşfet
                    </h3>

                    <p class="feature-description">
                        Sisteme eklenen şarkıları incele ve yeni müziklerle
                        tanış.
                    </p>

                </div>

                <div class="feature-card">

                    <div class="feature-icon">
                        ★
                    </div>

                    <h3 class="feature-title">
                        Sanatçıları takip et
                    </h3>

                    <p class="feature-description">
                        Sevdiğin sanatçıları görüntüle ve çalışmalarını
                        kolayca takip et.
                    </p>

                </div>

                <div class="feature-card">

                    <div class="feature-icon">
                        ♥
                    </div>

                    <h3 class="feature-title">
                        Favorilerini oluştur
                    </h3>

                    <p class="feature-description">
                        Beğendiğin şarkıları kaydet ve kişisel müzik
                        koleksiyonunu oluştur.
                    </p>

                </div>

            </div>

        </section>

    </main>

    <footer class="footer">

        <p>
            © @DateTime.Now.Year MusicProject
        </p>

        <p>
            Müziği keşfet, ritmi yakala.
        </p>

    </footer>

</body>
</html>